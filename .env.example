# GitHub fine-grained PAT con permisos Issues:Read + Metadata:Read.
# Genéralo en https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# Tu usuario de GitHub (sólo se usa para mostrarlo en el header).
GITHUB_USER=

# LLM local con API compatible OpenAI (LMStudio, Ollama con OpenAI compat, llama.cpp server…).
# Si no está disponible, el dashboard funciona igual: las issues aparecerán como "pendiente de análisis".
#   LMStudio: http://localhost:1234/v1  (deja el servidor activo en la pestaña "Developer")
#   Ollama:   http://localhost:11434/v1 (Ollama también expone /v1 compatible OpenAI)
LLM_URL=http://localhost:1234/v1
LLM_MODEL=local-model
# Solo lo usan algunos servidores; LMStudio acepta cualquier string.
LLM_API_KEY=lm-studio

# Cada cuánto barrer los repos (milisegundos).
# 30 min = 1800000 · 10 min = 600000 · 5 min = 300000
SENTINEL_INTERVAL_MS=1800000

# Ruta al SQLite. Puede ser relativa al proyecto o absoluta.
SENTINEL_DB_PATH=data/sentinel.db

# Servidor HTTP.
PORT=3741
# Usa 0.0.0.0 solo si quieres exponerlo en tu red local.
HOST=127.0.0.1

# Notificaciones de WhatsApp vía CallMeBot (gratis).
# 1) Añade el contacto "+34 644 36 84 26" (o el indicado en https://www.callmebot.com/blog/free-api-whatsapp-messages/)
# 2) Mándale por WhatsApp: "I allow callmebot to send me messages"
# 3) Te responderá con tu API key personal.
WHATSAPP_PHONE=                # tu número con código país, ej. 34666123456 (sin + ni espacios)
CALLMEBOT_API_KEY=             # API key que te da CallMeBot al activarte
WHATSAPP_ENABLED=true          # pon false para pausar sin borrar las creds
WHATSAPP_TIMEZONE=Europe/Madrid
WHATSAPP_MORNING_HOUR=9        # 0-23, hora local del digest matutino
WHATSAPP_EVENING_HOUR=18       # 0-23, hora local del digest vespertino

# Autores extra a considerar "internos" (no aparecen como PRs externos), separados por comas.
# El owner del repo y GITHUB_USER ya se consideran internos automáticamente.
INTERNAL_AUTHORS=
